font-weight:600;
cursor:pointer;
}

.contact-box{
background:#111;
padding:50px;
border-radius:20px;
text-align:center;
}

.contact-buttons{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
margin-top:20px;
}

.contact-buttons a{
background:var(--gold);
color:black;
