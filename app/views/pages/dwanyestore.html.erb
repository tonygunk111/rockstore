*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

html{
scroll-behavior:smooth;
}

:root{
--gold:#d4af37;
--dark:#0b0b0b;
--card:#151515;
--text:#f5f5f5;
--gray:#cfcfcf;
}

body{
background:var(--dark);
color:var(--text);
overflow-x:hidden;
}

.container{
width:90%;
max-width:1300px;
margin:auto;
}

header{
background:
linear-gradient(rgba(0,0,0,.75),rgba(0,0,0,.75)),
url("images/dwayne-johnson-hero.jpg");
background-size:cover;
background-position:center;
min-height:20vh;
}

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 0;
position:sticky;
top:0;
z-index:1000;
}

.logo{
font-size:2rem;
font-weight:800;
color:var(--gold);
}

.nav-links{
display:flex;
gap:25px;
list-style:none;
}

.nav-links a{
text-decoration:none;
color:white;
font-weight:500;
}

.menu-toggle{
display:none;
font-size:2rem;
cursor:pointer;
}

.hero{
height:85vh;
display:flex;
align-items:center;
}

.hero-content{
max-width:700px;
}

.hero h1{
font-size:4rem;
margin-bottom:20px;
}

.hero p{
font-size:1.1rem;
margin-bottom:25px;
}

.btn{
display:inline-block;
padding:14px 30px;
border-radius:40px;
text-decoration:none;
font-weight:600;
transition:.3s;
}

.btn-primary{
background:var(--gold);
color:black;
}

.btn:hover{
transform:translateY(-4px);
}

section{
padding:100px 0;
}

.section-title{
text-align:center;
font-size:2.7rem;
margin-bottom:20px;
color:var(--gold);
}

.section-sub{
text-align:center;
max-width:700px;
margin:auto;
margin-bottom:50px;
}

.about-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:50px;
align-items:center;
}

.about-grid img{
width:100%;
border-radius:20px;
}

.card-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:30px;
}

.card{
background:var(--card);
border-radius:20px;
overflow:hidden;
transition:.4s;
}

.card:hover{
transform:translateY(-10px);
}

.card img{
width:100%;
height:250px;
object-fit:cover;
}

.card-content{
padding:25px;
}

.price{
color:var(--gold);
font-size:1.4rem;
font-weight:700;
margin-top:10px;
}

.membership{
text-align:center;
background:#111;
padding:40px;
border-radius:20px;
}

table{
width:100%;
border-collapse:collapse;
margin-top:30px;
}

table th{
background:var(--gold);
color:black;
}

table th,
table td{
padding:18px;
border:1px solid #333;
}

table tr:nth-child(even){
background:#1a1a1a;
}

.testimonials{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:30px;
}

.testimonial{
background:#151515;
padding:25px;
border-radius:20px;
}

.faq-item{
margin-bottom:20px;
background:#151515;
padding:20px;
border-radius:15px;
}

.newsletter{
text-align:center;
background:#111;
padding:50px;
border-radius:20px;
}

