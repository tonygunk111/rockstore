margin:10px;
}

.newsletter button{
padding:15px 25px;
background:var(--gold);
border:none;
font-weight:600;
cursor:pointer;
}

.contact-box{
background:#111;
padding:50px;
border-radius:20px;
text-align:center;
}

.contact-buttons{
display:flex;
justify-content:center;
gap:20px;
flex-wrap:wrap;
margin-top:20px;
}

.contact-buttons a{
background:var(--gold);
color:black;
text-decoration:none;
padding:15px 30px;
border-radius:40px;
font-weight:700;
}

.floating-whatsapp{
position:fixed;
bottom:20px;
right:20px;
background:#25D366;
color:white;
padding:15px 20px;
border-radius:50px;
text-decoration:none;
font-weight:700;
z-index:999;
}

footer{
background:#050505;
padding:25px;
text-align:center;
}

@media(max-width:900px){

